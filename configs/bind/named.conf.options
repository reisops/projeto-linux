options {
    directory "/var/cache/bind";

    recursion yes;
    allow-query { any; };
    allow-recursion { 192.168.10.0/24; localhost; };

    forwarders {
        8.8.8.8;
        8.8.4.4;
    };

    dnssec-validation auto;
    listen-on { 192.168.10.1; 127.0.0.1; };
    listen-on-v6 { none; };
};

